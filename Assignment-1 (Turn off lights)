#include <bits/stdc++.h>
using namespace std;

bool possible(string &bulbs, int n, int m, int k) {
    int ops = 0;

    for (int i = 0; i < n; ) {
        if (bulbs[i] == '1') {
            ops++;
            i += k;   // this operation covers k bulbs
        } else {
            i++;
        }
    }

    return ops <= m;
}

int main() {
    int n, m;
    cin >> n >> m;

    string bulbs;
    cin >> bulbs;

    int low = 1, high = n, ans = n;

    while (low <= high) {
        int mid = (low + high) / 2;

        if (possible(bulbs, n, m, mid)) {
            ans = mid;
            high = mid - 1;
        } else {
            low = mid + 1;
        }
    }

    cout << ans << endl;

    return 0;
}
